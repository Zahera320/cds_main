# Example Environment Configuration for Enhanced Text Extraction
# Copy this to .env and adjust values as needed

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/docupload

# Security Settings
SECRET_KEY=your-random-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# File Upload Settings
MAX_FILE_SIZE_MB=100
STORAGE_PATH=storage
CORS_ORIGINS=*

# Enhanced Text Extraction Settings
# =================================

# Base OCR threshold (characters) - will be adjusted based on page size
# Lower values make OCR more aggressive, higher values prefer native text
BASE_OCR_THRESHOLD=30

# Minimum text density (characters per square inch) for digital documents
# Pages below this density are more likely to be treated as scanned
MIN_TEXT_DENSITY=2.0

# Maximum ratio of garbled/corrupted characters before triggering OCR
# 0.3 means if >30% of characters look garbled, try OCR instead
MAX_GARBLED_RATIO=0.3

# Enable enhanced OCR processing for difficult pages
# true: Use higher DPI and image preprocessing for better accuracy
# false: Use standard OCR processing only
OCR_ENHANCED_MODE=true

# Additional Tesseract Configuration (advanced users)
# These are applied automatically by the enhanced OCR system:
# - OEM 3: Use default OCR Engine Mode
# - PSM 6: Assume uniform block of text
# - Custom character whitelist for better accuracy
# - Higher DPI rendering for enhanced mode (400 vs 300)
# - Image preprocessing: grayscale, contrast enhancement, sharpening

# AWS Textract for Table Extraction (Premium)
# Set to true to use AWS Textract paid API for superior table extraction
# Provides better structure recognition for complex lighting fixture schedules
# Requires AWS credentials (AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY)
USE_AWS_TEXTRACT_FOR_TABLES=true